# Frontend Environment Variables Template
# Copy this file to .env.local for local development or .env.production for production

# Backend API URL
# Local development: http://localhost:4000
# Production: http://164.92.249.220:4000 (or your production backend URL)
NEXT_PUBLIC_ECOM_API_URL=http://localhost:4000

# Strapi CMS Configuration (optional - only if using Strapi)
# NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# NEXT_PUBLIC_STRAPI_API_KEY=your_strapi_api_key_here

# Image Upload Service (server-side only, not exposed to browser)
# IMGHIPPO_API_KEY=your_imghippo_api_key_here

# Optional background remover (server-side upload route only)
# Set to true to enable preprocessing during image upload
BG_REMOVER_ENABLED=false
# Prefer subdomain URL in production, e.g. https://bg.shreeji.co.zm
BG_REMOVER_API_URL=http://localhost:4200
# Timeout for background-removal request in milliseconds
BG_REMOVER_TIMEOUT_MS=15000
